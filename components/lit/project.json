{
  "name": "@minho-friends/friend-design-system--lit",
  "projectType": "library",
  "root": "components/lit",
  "sourceRoot": "components/lit/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "npm run build",
        "cwd": "components/lit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --test __tests__/*.test.js",
        "cwd": "components/lit"
      }
    }
  }
}
