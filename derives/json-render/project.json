{
  "name": "@minho-friends/friend-design-system--json-render",
  "projectType": "library",
  "root": "derives/json-render",
  "implicitDependencies": [
    "@minho-friends/friend-design-system--shadcn-registry"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "command": "npm run build",
        "cwd": "derives/json-render"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --test __tests__/*.test.js",
        "cwd": "derives/json-render"
      }
    }
  }
}
